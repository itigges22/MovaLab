# =====================================================
# MOVALAB ENVIRONMENT CONFIGURATION
# =====================================================
# Self-hosted with local Supabase (Docker)
#
# SETUP:
#   1. Copy this file: cp .env.local.template .env.local
#   2. Install Docker Desktop
#   3. Run: npm run docker:start
#   4. Run: npm run docker:seed
#   5. Run: npm run dev
#   6. Open: http://localhost:3000
#   7. Login: superadmin@test.local / Test1234!

# =====================================================
# SUPABASE (LOCAL DOCKER)
# =====================================================
# These are the default local Supabase credentials.
# They work out of the box with `supabase start`.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# =====================================================
# APP SETTINGS
# =====================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=debug
NODE_ENV=development

# Demo mode (set to true for quick-login buttons + blocked destructive actions)
NEXT_PUBLIC_DEMO_MODE=false

# =====================================================
# SECURITY (Change these before going live!)
# =====================================================

# Used to create the first superadmin account at /setup
# Generate with: openssl rand -hex 32
# SETUP_SECRET=change-me-to-something-secure

# Required for scheduled cron jobs
# CRON_SECRET=change-me-to-something-secure

# =====================================================
# TEST USERS (all password: Test1234!)
# =====================================================
# superadmin@test.local  - Super Admin (full access)
# exec@test.local        - Executive Director
# manager@test.local     - Account Manager
# pm@test.local          - Project Manager
# admin@test.local       - Admin (workflows, roles)
# designer@test.local    - Senior Designer
# dev@test.local         - Senior Developer
# contributor@test.local - Contributor
# client@test.local      - Client (portal only)

# =====================================================
# OPTIONAL: RATE LIMITING
# =====================================================
# For production, add Upstash Redis for API rate limiting
# UPSTASH_REDIS_REST_URL=your_upstash_redis_url
# UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token
# ENABLE_RATE_LIMIT=true
